{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh",
            "args": ["-NoProfile", "-File", "${CLAUDE_PROJECT_DIR}/.claude/hooks/evaluar-slide.ps1"],
            "statusMessage": "Evaluando contenido del slide..."
          }
        ]
      }
    ]
  }
}
